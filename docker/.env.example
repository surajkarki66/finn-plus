# Match container file ownership to your host user (auto-detected by run-docker.sh)
HOST_UID=1000
HOST_GID=1000

# Where Vivado/Vitis is installed ON THE HOST.
# Must be mounted at the same path in the container (Xilinx scripts use absolute paths).
FINN_XILINX_PATH=/tools/Xilinx

# Tool version you installed (must match a folder under FINN_XILINX_PATH/Vivado/ and /Vitis/)
FINN_XILINX_VERSION=2024.2

# License — use a server hostname (works as-is) or mount a license file path
# XILINXD_LICENSE_FILE=2100@license-server.example.com
# XILINXD_LICENSE_FILE=/opt/Xilinx/Xilinx.lic
# Parallel workers for HLS / Vivado
NUM_DEFAULT_WORKERS=4

# Development setup flags (see docker/entrypoint.sh — follows wiki Quick Start Option B)
# FINN_FORCE_POETRY_INSTALL=0   # re-run `poetry install`
# FINN_FORCE_DEPS_UPDATE=0      # re-run `finn deps update`
# FINN_FORCE_CHECK=0            # re-run `finn check`
