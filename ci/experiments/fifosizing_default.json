{
    "global": {
      "driver": "driver/driver.py",
      "bitfile_name": "bitfile/finn-accel.bit",
      "report_path": "report",

      "PAF": {
        "rails": [
          "0V85",
          "3V3"
        ],
        "sensors": []
      }
    },
    "experiments": [
      {
        "name": "experiment_fifosizing",
        "warmup": 1,
        "num_runs": 1,
        "functions": [
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "forward", "stop_condition": "interval", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "forward", "stop_condition": "latency", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "forward", "stop_condition": "both", "relaxation": 0.0, "relaxation_sweep": false}
          },

          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "reverse", "stop_condition": "interval", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "reverse", "stop_condition": "latency", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "reverse", "stop_condition": "both", "relaxation": 0.0, "relaxation_sweep": false}
          },

          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "largest_first", "stop_condition": "interval", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "largest_first", "stop_condition": "latency", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "largest_first", "stop_condition": "both", "relaxation": 0.0, "relaxation_sweep": true}
          },

          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "deepest_first", "stop_condition": "interval", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "deepest_first", "stop_condition": "latency", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "deepest_first", "stop_condition": "both", "relaxation": 0.0, "relaxation_sweep": false}
          },

          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "alternating", "stop_condition": "interval", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "alternating", "stop_condition": "latency", "relaxation": 0.0, "relaxation_sweep": false}
          },
          {
            "function_name": "experiment_fifosizing",
            "kwargs": {"fifo_search_order": "alternating", "stop_condition": "both", "relaxation": 0.0, "relaxation_sweep": false}
          }
        ]
      }
    ]
  }
